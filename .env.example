APP_NAME=IceFrame
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_TIMEZONE=America/Costa_Rica

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ------------------------------------------------------------
# Base de datos PostgreSQL (Parte 2 / Juan Diego)
# La prueba final usa la IP Tailscale de Juan Diego y DB_PORT=5433.
# NUNCA usar localhost para la base remota.
# Para desarrollo local con el mismo init.sql puede usarse 127.0.0.1.
# ------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=IP_TAILSCALE_DE_JUAN_DIEGO
DB_PORT=5433
DB_DATABASE=iceframe
DB_USERNAME=iceframe
DB_PASSWORD=iceframe_dev
# Conexión persistente: reutiliza la conexión a la BD remota entre peticiones
# (más fluido por Tailscale). Pon false si causa problemas.
DB_PERSISTENT=true

# Sesiones por archivo (no se crean tablas en la BD compartida).
SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file

# ------------------------------------------------------------
# Módulo de reportes (Contenedor B del Estudiante 2).
# URL del servicio de reportes accesible por la red Tailscale.
# Ej.: http://IP_TAILSCALE_DE_JUAN_DIEGO:PUERTO_REPORTES
# El botón "Ver reportes" del dashboard usa esta URL.
# ------------------------------------------------------------
REPORTES_URL=
